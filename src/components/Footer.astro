---
interface Props {
  t: {
    meta: string;
  };
}

const { t } = Astro.props;
---

<footer>
  <div class="container">
    <div class="foot-left">
      <div class="foot-logo">licit<span class="red">.</span></div>
      <a href="https://diego303.github.io/oss-ecosystem-project/" class="foot-ecosystem">OSS Ecosystem Project</a>
    </div>
    <div class="foot-meta">{t.meta}</div>
  </div>
</footer>

<style>
  footer {
    padding: 32px 0;
  }

  footer .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .foot-left {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }

  .foot-logo {
    font-size: 18px;
    font-weight: 800;
  }

  .foot-logo .red {
    color: var(--red);
  }

  .foot-ecosystem {
    font-family: 'Overpass Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--g4);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.15s;
  }

  .foot-ecosystem:hover {
    color: var(--red);
  }

  .foot-meta {
    font-family: 'Overpass Mono', monospace;
    font-size: 11px;
    color: var(--g4);
    letter-spacing: 0.5px;
  }
</style>
