---
import type { Locale } from '../i18n/translations';
import { getDocsUrl } from '../i18n/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  lang: Locale;
  versionLabel: string;
  t: {
    back_link: string;
    toc_title: string;
  };
}

const { headings, lang, versionLabel, t } = Astro.props;
const docsUrl = getDocsUrl(lang);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<aside class="doc-sidebar">
  <button class="sidebar-toggle" aria-label="Toggle sidebar" aria-expanded="false">
    <span class="sidebar-toggle-text">{t.toc_title}</span>
    <span class="sidebar-toggle-icon"></span>
  </button>

  <div class="sidebar-inner">
    <a href={docsUrl} class="back-link">{t.back_link}</a>
    <span class="version-tag">{versionLabel}</span>

    {
      tocHeadings.length > 0 && (
        <div class="sidebar-section">
          <div class="sidebar-title">{t.toc_title}</div>
          <ul class="sidebar-toc">
            {tocHeadings.map((h) => (
              <li class={h.depth === 3 ? 'indent' : ''}>
                <a href={`#${h.slug}`} data-toc-link>
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</aside>

<script>
  function initScrollSpy() {
    const links = document.querySelectorAll('[data-toc-link]');
    if (!links.length) return;

    const headings = Array.from(links).map((link) => {
      const id = link.getAttribute('href')?.replace('#', '') ?? '';
      return document.getElementById(id);
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove('active'));
            const active = document.querySelector(
              `[data-toc-link][href="#${entry.target.id}"]`
            );
            active?.classList.add('active');
          }
        });
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0 }
    );

    headings.forEach((h) => observer.observe(h));
  }

  function initSidebarToggle() {
    const toggle = document.querySelector('.sidebar-toggle') as HTMLButtonElement;
    const inner = document.querySelector('.sidebar-inner') as HTMLElement;
    if (!toggle || !inner) return;

    toggle.addEventListener('click', () => {
      const isOpen = toggle.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      inner.classList.toggle('open');
    });

    inner.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          toggle.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
          inner.classList.remove('open');
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initScrollSpy();
    initSidebarToggle();
  });
</script>

<style>
  .doc-sidebar {
    position: sticky;
    top: 66px;
    height: calc(100vh - 66px);
    overflow-y: auto;
    padding: 32px 28px;
    border-right: 2px solid var(--black);
  }

  .sidebar-toggle {
    display: none;
  }

  .back-link {
    display: block;
    font-family: 'Overpass Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    color: var(--g3);
    text-decoration: none;
    margin-bottom: 12px;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--black);
  }

  .version-tag {
    display: inline-block;
    font-family: 'Overpass Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--g4);
    letter-spacing: 1px;
    border: 1px solid var(--g5);
    padding: 4px 10px;
    margin-bottom: 28px;
  }

  .sidebar-section {
    margin-bottom: 28px;
  }

  .sidebar-title {
    font-family: 'Overpass Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--red);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--g6);
  }

  .sidebar-toc {
    list-style: none;
  }

  .sidebar-toc li {
    margin-bottom: 2px;
  }

  .sidebar-toc a {
    display: block;
    font-size: 13px;
    color: var(--g3);
    text-decoration: none;
    padding: 6px 12px;
    transition: all 0.15s;
  }

  .sidebar-toc a:hover {
    color: var(--black);
  }

  .sidebar-toc a:global(.active) {
    color: var(--black);
    font-weight: 600;
  }

  .sidebar-toc .indent a {
    padding-left: 24px;
    font-size: 12px;
  }

  /* ── Mobile ── */

  @media (max-width: 768px) {
    .doc-sidebar {
      position: relative;
      top: auto;
      height: auto;
      overflow-y: visible;
      padding: 0;
      border-right: none;
      border-bottom: 2px solid var(--black);
    }

    .sidebar-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      background: none;
      border: none;
      cursor: pointer;
      padding: 16px 24px;
      font-family: 'Overpass Mono', monospace;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--g2);
    }

    .sidebar-toggle-icon {
      display: block;
      width: 10px;
      height: 10px;
      border-right: 2px solid var(--black);
      border-bottom: 2px solid var(--black);
      transform: rotate(45deg);
      transition: transform 0.2s;
    }

    .sidebar-toggle.open .sidebar-toggle-icon {
      transform: rotate(-135deg);
    }

    .sidebar-inner {
      display: none;
      padding: 0 24px 24px;
    }

    .sidebar-inner.open {
      display: block;
    }

    .back-link {
      margin-bottom: 8px;
    }

    .version-tag {
      margin-bottom: 20px;
    }
  }
</style>
