---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { getTranslations } from '../../../i18n/utils';
import { getDocSlug, getLatestVersion, getVersionFromDocId } from '../../../config/versions';

export async function getStaticPaths() {
  const allDocs = await getCollection('docs-en');
  const latest = getLatestVersion();

  return allDocs.map((entry) => {
    const isLatest = entry.id.startsWith(latest.id + '/');
    const slug = isLatest ? getDocSlug(entry.id) : entry.id;

    return {
      params: { slug },
      props: { entry },
    };
  });
}

const lang = 'en' as const;
const t = getTranslations(lang);
const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const version = getVersionFromDocId(entry.id);
---

<DocsLayout
  title={`${entry.data.title} | Licit`}
  description={entry.data.description}
  lang={lang}
  headings={headings}
  versionLabel={version?.label ?? getLatestVersion().label}
  t={t.docs_page}
>
  <Content />
</DocsLayout>
