---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import DocSidebar from '../components/DocSidebar.astro';
import Footer from '../components/Footer.astro';
import { getTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/translations';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  lang: Locale;
  headings: Heading[];
  versionLabel: string;
  t: {
    back_link: string;
    toc_title: string;
  };
}

const { title, description, lang, headings, versionLabel, t } = Astro.props;
const fullT = getTranslations(lang);
---

<Layout title={title} description={description} lang={lang}>
  <Navbar t={fullT.nav} lang={lang} />
  <div class="docs-layout">
    <DocSidebar
      headings={headings}
      lang={lang}
      versionLabel={versionLabel}
      t={t}
    />
    <main class="docs-content">
      <slot />
    </main>
  </div>
  <Footer t={fullT.footer} />
</Layout>

<script>
  // Wrap markdown-generated tables in scrollable container
  document.querySelectorAll('.docs-content table').forEach((table) => {
    if (table.parentElement?.classList.contains('table-wrapper')) return;
    const wrapper = document.createElement('div');
    wrapper.className = 'table-wrapper';
    table.parentNode?.insertBefore(wrapper, table);
    wrapper.appendChild(table);
  });
</script>

<style is:global>
  .docs-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: calc(100vh - 66px);
  }

  @media (max-width: 768px) {
    .docs-layout {
      grid-template-columns: 1fr;
    }
  }

  /* ═══════════════════════════════════════════
     PROSE — Markdown content styling
     Following Licit Design System section 8.4
     ═══════════════════════════════════════════ */

  .docs-content {
    padding: 48px 64px 80px;
    max-width: 800px;
    min-width: 0;
    overflow-wrap: break-word;
  }

  .docs-content h1,
  .docs-content h2,
  .docs-content h3,
  .docs-content h4 {
    scroll-margin-top: 80px;
  }

  .docs-content h1 {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -1.5px;
    margin-bottom: 24px;
    line-height: 1.1;
    border-bottom: 2px solid var(--black);
    padding-bottom: 16px;
  }

  .docs-content h2 {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -1px;
    margin-top: 48px;
    margin-bottom: 16px;
    line-height: 1.15;
  }

  .docs-content h3 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .docs-content h4 {
    font-size: 16px;
    font-weight: 700;
    margin-top: 24px;
    margin-bottom: 8px;
  }

  .docs-content p {
    font-size: 16px;
    color: var(--g2);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .docs-content a {
    color: var(--red);
    text-decoration: none;
  }

  .docs-content a:hover {
    text-decoration: underline;
  }

  .docs-content strong {
    font-weight: 700;
    color: var(--black);
  }

  .docs-content ul,
  .docs-content ol {
    margin-bottom: 16px;
    padding-left: 0;
    list-style: none;
  }

  /* Nested lists: add indentation per level */
  .docs-content li > ul,
  .docs-content li > ol {
    margin-top: 6px;
    margin-bottom: 0;
    padding-left: 20px;
  }

  .docs-content ul li,
  .docs-content ol li {
    font-size: 16px;
    color: var(--g2);
    line-height: 1.65;
    margin-bottom: 6px;
    padding-left: 20px;
    position: relative;
  }

  .docs-content ul li::before {
    content: '\2014';
    color: var(--g5);
    position: absolute;
    left: 0;
  }

  .docs-content ol {
    counter-reset: list-counter;
  }

  .docs-content ol li {
    counter-increment: list-counter;
  }

  .docs-content ol li::before {
    content: counter(list-counter) '.';
    color: var(--g4);
    position: absolute;
    left: 0;
    font-family: 'Overpass Mono', monospace;
    font-size: 13px;
    font-weight: 600;
  }

  .docs-content blockquote {
    border-left: 2px solid var(--red);
    padding-left: 20px;
    margin: 16px 0;
    font-style: italic;
    color: var(--g3);
  }

  .docs-content blockquote p {
    color: inherit;
  }

  .docs-content img {
    max-width: 100%;
    height: auto;
  }

  .docs-content code {
    font-family: 'Overpass Mono', monospace;
    font-size: 0.88em;
    background: var(--g7);
    padding: 2px 6px;
    border: 1px solid var(--g6);
    word-break: break-word;
  }

  .docs-content pre {
    background: var(--black);
    color: white;
    font-family: 'Overpass Mono', monospace;
    font-size: 13px;
    line-height: 2;
    padding: 24px 28px;
    margin: 16px 0 24px;
    overflow-x: auto;
    border: 2px solid var(--black);
  }

  .docs-content pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 13px;
    color: inherit;
    word-break: normal;
  }

  .docs-content table {
    min-width: 100%;
    border: 2px solid var(--black);
    border-collapse: collapse;
    margin: 16px 0 24px;
  }

  /* Scrollable wrapper for wide tables on small screens */
  .docs-content .table-wrapper {
    overflow-x: auto;
    margin: 16px 0 24px;
  }

  .docs-content .table-wrapper table {
    margin: 0;
  }

  .docs-content thead {
    background: var(--black);
    color: var(--bg);
  }

  .docs-content th {
    font-family: 'Overpass Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 12px 16px;
    text-align: left;
    border-right: 1px solid #333;
  }

  .docs-content th:last-child {
    border-right: none;
  }

  .docs-content td {
    font-size: 14px;
    color: var(--g2);
    padding: 12px 16px;
    border-bottom: 1px solid var(--g5);
    border-right: 1px solid var(--g5);
  }

  .docs-content td:last-child {
    border-right: none;
  }

  .docs-content tr:last-child td {
    border-bottom: none;
  }

  .docs-content hr {
    border: none;
    border-top: 1px solid var(--g5);
    margin: 32px 0;
  }

  @media (max-width: 768px) {
    .docs-content {
      padding: 32px 24px 64px;
    }

    .docs-content h1 {
      font-size: 28px;
      letter-spacing: -1px;
    }

    .docs-content h2 {
      font-size: 22px;
      margin-top: 36px;
    }

    .docs-content h3 {
      font-size: 18px;
    }

    .docs-content pre {
      padding: 16px;
      font-size: 12px;
    }

    .docs-content td,
    .docs-content th {
      padding: 8px 12px;
      font-size: 12px;
    }

    .docs-content th {
      font-size: 9px;
      letter-spacing: 1px;
    }
  }
</style>
